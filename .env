# Delta Exchange API credentials
# Get these from: Delta Exchange account → API Management → Create API
# Withdrawals: OFF. IP whitelist: ON.

DELTAEXCHANGE_API_KEY=your_api_key_here
DELTAEXCHANGE_SECRET_KEY=your_secret_key_here
DELTAEXCHANGE_PASSPHRASE=
DELTAEXCHANGE_BASE_URL=https://api.delta.exchange




# Trading mode: "spot" or "futures"
TRADE_MODE=futures

# Portfolio value — used to calculate position size
PORTFOLIO_VALUE_USD=1000

# Trade limits — these are your guardrails
MAX_TRADE_SIZE_USD=1000        # No single trade can exceed this value
MAX_TRADES_PER_DAY=100         # Bot stops executing after this many trades in a calendar day

# Symbols to trade (comma-separated)
# For Delta Exchange: PAXGUSD, BTCUSD, ETHUSD, SOLUSD
# For other exchanges: BTCUSDT,ETHUSDT,etc
SYMBOLS=PAXGUSD,BTCUSD,ETHUSD,SOLUSD

# Using Delta Exchange for market data
# Set to false to fetch real market data
SKIP_DATA_FETCH=false

# Timeframe for analysis (1m, 15m, 1h, 4h, 1d)
TIMEFRAME=15m

# Set to "true" to run in paper trading mode (logs decisions but never places real orders)
PAPER_TRADING=true

# Trading Configuration
PORTFOLIO_VALUE_USD=10000
MAX_TRADE_SIZE_USD=250
MAX_TRADES_PER_DAY=5
PAPER_TRADING=true
SYMBOL=EURUSDT
TIMEFRAME=15m
TRADE_MODE=future

# DRT Strategy Parameters
DRT_ENABLED=true
DAILY_BIAS_LOOKBACK=3
PO3_CONFIRMATION_REQUIRED=2
ATR_PERIOD=14
STOP_LOSS_MULTIPLIER=2.5
TAKE_PROFIT_RATIOS=1,2,3
