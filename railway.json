{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "startCommand": "node bot.js",
    "cronSchedule": "0 */4 * * *",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "runCommandAfterDeploy": "node manage-trades.js extract"
  }
}