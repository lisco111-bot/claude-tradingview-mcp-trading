# Railway Environment Variables - Copy these to Railway dashboard
# Settings > Variables > New Variable

# Trading Configuration
PORTFOLIO_VALUE_USD=10000
MAX_TRADE_SIZE_USD=250
MAX_TRADES_PER_DAY=5
PAPER_TRADING=true
SYMBOL=EURUSDT
TIMEFRAME=15m
TRADE_MODE=future
EXCHANGE=binance

# DRT Strategy Parameters
DRT_ENABLED=true
DAILY_BIAS_LOOKBACK=3
PO3_CONFIRMATION_REQUIRED=2
ATR_PERIOD=14
STOP_LOSS_MULTIPLIER=2.5
TAKE_PROFIT_RATIOS=1,2,3

# API Credentials - REQUIRED for live trading
BINANCE_API_KEY=your_actual_binance_api_key
BINANCE_SECRET_KEY=your_actual_binance_secret_key
BINANCE_PASSPHRASE=your_actual_binance_passphrase

# Optional - Delta Exchange
DELTA_API_KEY=your_delta_api_key
DELTA_SECRET_KEY=your_delta_secret_key
DELTA_PASSPHRASE=your_delta_passphrase